{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compilar e Rodar ERP",
            "type": "shell",
            "command": "g++ -std=c++14 *.cpp -o erp.exe; ./erp.exe",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": true
            },
            "detail": "Compila todos os .cpp e ja executa no terminal integrado"
        }
    ]
}
